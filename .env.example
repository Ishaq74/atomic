# ── Environnement DB ( LOCAL | PROD | TEST ) ─────────────────────────────────────────────────
DB_ENV=LOCAL

# ── URLs de connexion PostgreSQL ─────────────────────────────────────
DATABASE_URL_LOCAL=postgresql://user:password@localhost:5432/db_local
DATABASE_URL_PROD=postgresql://user:password@localhost:5432/db_prod
DATABASE_URL_TEST=postgresql://user:password@localhost:5432/db_test

# ── Sécurité PROD ───────────────────────────────────────────────────
# Mettre "oui" pour autoriser les opérations sur PROD en CI/CD (sans prompt interactif)
# CONFIRM_PROD=oui

# ── Pool (optionnel) ────────────────────────────────────────────────
# Surcharge la taille max du pool (défaut : LOCAL=10, TEST=5, PROD=20)
# DB_POOL_MAX=10

# ── Authentification ( Better-Auth ) ───────────────────────────────
BETTER_AUTH_SECRET=replace-me-with-a-secure-random-secret-min-32-chars
BETTER_AUTH_URL=http://localhost:4321

# ── Site URL (Astro) ────────────────────────────────────────────────
SITE_URL=http://localhost:4321

# ── SMTP ( BREVO | RESEND | NODEMAILER ) ────────────────────────────
SMTP_PROVIDER=NODEMAILER
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Atomic

# ── Nodemailer (SMTP générique) ──────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# ── Brevo (API v3) ──────────────────────────────────────────────────
# BREVO_API_KEY=xkeysib-...

# ── Resend ──────────────────────────────────────────────────────────
# RESEND_API_KEY=re_...

# ── Test ────────────────────────────────────────────────────────────
# SMTP_TEST_TO=test@example.com

# ── LHCI ( Lighthouse CI ) ─────────────────────────────────────────────
# LHCI_GITHUB_APP_TOKEN=your-lhci-token-here

# ── Reverse Proxy ──────────────────────────────────────────────────
# Set to "true" ONLY when behind a trusted reverse proxy (nginx, Caddy, CloudFlare)
# that overwrites x-forwarded-for / x-real-ip headers. Required for IP-based
# rate limiting and audit trail on public endpoints (contact form, auth).
# TRUST_PROXY=true

# ── Health Check ───────────────────────────────────────────────────
# Shared secret to access GET /api/health. If unset, only non-proxied (loopback)
# requests are accepted (suitable for container probes). For external monitoring
# tools, set a strong random token and pass it as `Authorization: Bearer <token>`.
# HEALTH_TOKEN=replace-with-a-strong-random-token

# ── Contact Form ───────────────────────────────────────────────────
# Email address that receives contact form submissions (falls back to SMTP_FROM_EMAIL)
# CONTACT_EMAIL=contact@example.com