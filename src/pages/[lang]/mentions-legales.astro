---
import { toLocale } from '@i18n/utils';
import { getPage } from '@database/loaders/page.loader';
import BaseLayout from '@layouts/BaseLayout.astro';
import LegalPage from '@pages/LegalPage.astro';

const locale = toLocale(Astro.params.lang);

// Legal content is CMS-driven: look up the legal page by its localized slug.
const slugMap: Record<string, string> = {
  fr: 'mentions-legales',
  en: 'legal-notice',
  es: 'aviso-legal',
  ar: '\u0627\u0644\u0634\u0631\u0648\u0637-\u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a\u0629',
};
const data = await getPage(locale, slugMap[locale] ?? 'mentions-legales');

if (!data) return Astro.redirect(`/${locale}/`);
---

<BaseLayout title={data.page.metaTitle ?? data.page.title}>
  <LegalPage data={data} />
</BaseLayout>
