---
import { toLocale, getLegalTranslations } from '@i18n/utils';
import BaseLayout from '@layouts/BaseLayout.astro';
import LegalPage from '@pages/LegalPage.astro';

const locale = toLocale(Astro.params.lang);
const t = await getLegalTranslations(locale);
---

<BaseLayout>
  <LegalPage t={t} />
</BaseLayout>
