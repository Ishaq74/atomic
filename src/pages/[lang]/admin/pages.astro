---
import { requireAdmin } from '@/lib/auth-guards';
import { getDrizzle } from '@database/drizzle';
import { pages, pageSections } from '@database/schemas';
import { asc, eq, count } from 'drizzle-orm';
import BaseLayout from '@layouts/BaseLayout.astro';
import AuthLayout from '@organisms/AuthLayout/AuthLayout.astro';
import AdminSidebar from '@organisms/AdminSidebar/AdminSidebar.astro';
import AdminPagesPage from '@pages/admin/AdminPagesPage.astro';
import AdminSectionsEditor from '@pages/admin/AdminSectionsEditor.astro';

export const prerender = false;

const result = await requireAdmin(Astro);
if ('redirect' in result) return result.redirect;
const { locale, authT } = result;

const db = getDrizzle();
const editId = Astro.url.searchParams.get('edit');

// ─── Edit mode: load page + sections ───
let editPage: typeof pages.$inferSelect | null = null;
let editSections: (typeof pageSections.$inferSelect)[] = [];
if (editId) {
  const [row] = await db.select().from(pages).where(eq(pages.id, editId)).limit(1);
  if (row) {
    editPage = row;
    editSections = await db
      .select()
      .from(pageSections)
      .where(eq(pageSections.pageId, editId))
      .orderBy(asc(pageSections.sortOrder));
  }
}

// ─── List mode: paginated pages ───
const PER_PAGE = 20;
const page = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);
const offset = (page - 1) * PER_PAGE;

const [allPages, [total]] = await Promise.all([
  db
    .select()
    .from(pages)
    .where(eq(pages.locale, locale))
    .orderBy(asc(pages.sortOrder))
    .limit(PER_PAGE)
    .offset(offset),
  db.select({ value: count() }).from(pages).where(eq(pages.locale, locale)),
]);
const totalPages = Math.max(1, Math.ceil((total?.value ?? 0) / PER_PAGE));
---

<BaseLayout title={editPage ? `${authT.admin.cms.pages.editPage} — ${editPage.title}` : authT.admin.cms.pages.title} description={authT.admin.cms.pages.description}>
  <AuthLayout title={editPage ? `${authT.admin.cms.pages.editPage} — ${editPage.title}` : authT.admin.cms.pages.title}>
    <AdminSidebar slot="sidebar" t={authT} locale={locale} activeItem="pages" />
    {editPage ? (
      <AdminSectionsEditor t={authT} locale={locale} page={editPage} sections={editSections} />
    ) : (
      <AdminPagesPage
        t={authT}
        locale={locale}
        pages={allPages}
        currentPage={page}
        totalPages={totalPages}
        baseUrl={Astro.url}
      />
    )}
  </AuthLayout>
</BaseLayout>
