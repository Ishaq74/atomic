---
import { requirePermission } from '@/lib/auth-guards';
import { fetchAdminUsers } from '@/lib/auth-data';
import BaseLayout from '@layouts/BaseLayout.astro';
import AuthLayout from '@organisms/AuthLayout/AuthLayout.astro';
import AdminSidebar from '@organisms/AdminSidebar/AdminSidebar.astro';
import AdminUsersPage from '@pages/admin/AdminUsersPage.astro';

export const prerender = false;

const result = await requirePermission(Astro, { user: ["list"] });
if ('redirect' in result) return result.redirect;
const { user, locale, authT } = result;

const { users: adminUsers } = await fetchAdminUsers(Astro.request.headers);
---

<BaseLayout title={authT.meta.admin.title} description={authT.meta.admin.description}>
  <AuthLayout title={authT.admin.tabs.users}>
    <AdminSidebar slot="sidebar" t={authT} locale={locale} activeItem="users" />
    <AdminUsersPage t={authT} locale={locale} user={user} adminUsers={adminUsers} />
  </AuthLayout>
</BaseLayout>
