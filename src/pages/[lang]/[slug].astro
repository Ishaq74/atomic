---
import type { PageId } from '@i18n/config';
import { toLocale, getCommonTranslations, getAboutTranslations, getContactTranslations, getLegalTranslations } from '@i18n/utils';
import BaseLayout from '@layouts/BaseLayout.astro';
import AboutPage from '@pages/AboutPage/AboutPage.astro';
import ContactPage from '@pages/ContactPage/ContactPage.astro';
import LegalPage from '@pages/LegalPage.astro';

export const prerender = false;

const locale = toLocale(Astro.params.lang);
const slug = Astro.params.slug;

if (!slug) return Astro.redirect(`/${locale}/`);

// Resolve pageId from the URL slug by checking the route map
const commonT = await getCommonTranslations(locale);
const pageId = (Object.entries(commonT.pageRoutes) as [PageId, string][])
  .find(([, s]) => s === slug)?.[0];

if (!pageId) return Astro.redirect(`/${locale}/`);

const translations = {
  about: () => getAboutTranslations(locale),
  contact: () => getContactTranslations(locale),
  legal: () => getLegalTranslations(locale),
} as const;

const t = await translations[pageId]();

const pages = {
  about: AboutPage,
  contact: ContactPage,
  legal: LegalPage,
};

const Page = pages[pageId];
---

<BaseLayout>
  <Page t={t as never} />
</BaseLayout>
