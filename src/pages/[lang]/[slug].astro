---
import type { PageId } from '@i18n/config';
import { toLocale, getCommonTranslations, getAboutTranslations, getContactTranslations } from '@i18n/utils';
import { getPage } from '@database/loaders/page.loader';
import BaseLayout from '@layouts/BaseLayout.astro';
import AboutPage from '@pages/AboutPage/AboutPage.astro';
import ContactPage from '@pages/ContactPage/ContactPage.astro';
import LegalPage from '@pages/LegalPage.astro';

export const prerender = false;

const locale = toLocale(Astro.params.lang);
const slug = Astro.params.slug;

if (!slug) return Astro.redirect(`/${locale}/`);

// Resolve pageId from the URL slug by checking the route map
const commonT = await getCommonTranslations(locale);
const pageId = (Object.entries(commonT.pageRoutes) as [PageId, string][])
  .find(([, s]) => s === slug)?.[0];

if (!pageId) return Astro.redirect(`/${locale}/`);

// Legal pages are CMS-driven — load from the database
const isLegal = pageId === 'legal';
const legalData = isLegal ? await getPage(locale, slug) : null;
if (isLegal && !legalData) return Astro.redirect(`/${locale}/`);

const translations = {
  about: () => getAboutTranslations(locale),
  contact: () => getContactTranslations(locale),
} as const;

const t = !isLegal ? await translations[pageId as 'about' | 'contact']() : null;

const pages = {
  about: AboutPage,
  contact: ContactPage,
};

const Page = !isLegal ? pages[pageId as 'about' | 'contact'] : null;
---

<BaseLayout title={isLegal ? (legalData!.page.metaTitle ?? legalData!.page.title) : undefined}>
  {isLegal && legalData ? (
    <LegalPage data={legalData} />
  ) : Page && t ? (
    <Page t={t as never} />
  ) : null}
</BaseLayout>
