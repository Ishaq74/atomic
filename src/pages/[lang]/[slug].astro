---
import type { PageId } from '@i18n/config';
import { LOCALES } from '@i18n/config';
import { toLocale, getCommonTranslations, getAboutTranslations, getContactTranslations } from '@i18n/utils';
import { getPage } from '@database/loaders/page.loader';
import BaseLayout from '@layouts/BaseLayout.astro';
import AboutPage from '@pages/AboutPage/AboutPage.astro';
import ContactPage from '@pages/ContactPage/ContactPage.astro';
import LegalPage from '@pages/LegalPage.astro';
import { getSiteSettings, getContactInfo } from '@database/loaders/site.loader';

export const prerender = false;

const locale = toLocale(Astro.params.lang);
const slug = Astro.params.slug;

if (!slug) return Astro.redirect(`/${locale}/`);

// Resolve pageId from the URL slug by checking the route map
const commonT = await getCommonTranslations(locale);
const pageId = (Object.entries(commonT.pageRoutes) as [PageId, string][])
  .find(([, s]) => s === slug)?.[0];

if (!pageId) return Astro.redirect(`/${locale}/`);

// Legal pages are CMS-driven — load from the database
const isLegal = pageId === 'legal';
const legalData = isLegal ? await getPage(locale, slug) : null;
if (isLegal && !legalData) return Astro.redirect(`/${locale}/`);

const translations = {
  about: () => getAboutTranslations(locale),
  contact: () => getContactTranslations(locale),
} as const;

const t = !isLegal ? await translations[pageId as 'about' | 'contact']() : null;

const pages = {
  about: AboutPage,
  contact: ContactPage,
};

const Page = !isLegal ? pages[pageId as 'about' | 'contact'] : null;

// ─── Compute alternate URLs for hreflang ────────────────────────────────────
const alternateUrls: Record<string, string> = {};
await Promise.all(
  LOCALES.map(async (loc) => {
    const locT = await getCommonTranslations(loc);
    const locSlug = locT.pageRoutes[pageId];
    if (locSlug) {
      alternateUrls[loc] = `/${loc}/${locSlug}`;
    }
  }),
);

const description = isLegal
  ? (legalData!.page.metaDescription ?? undefined)
  : undefined;

// ─── Interpolate template variables in legal page meta fields ───────────────
let interpolatedTitle: string | undefined;
let interpolatedDescription: string | undefined;

if (isLegal && legalData) {
  const [siteData, contactData] = await Promise.all([
    getSiteSettings(locale),
    getContactInfo(),
  ]);
  const vars: Record<string, string> = {
    siteName: siteData?.siteName ?? '',
    email: contactData?.email ?? '',
    phone: contactData?.phone ?? '',
    address: contactData?.address ?? '',
    city: contactData?.city ?? '',
    postalCode: contactData?.postalCode ?? '',
    country: contactData?.country ?? '',
  };
  const interpolate = (text: string) =>
    text.replace(/\{\{(\w+)\}\}/g, (_, key) => vars[key] ?? '');

  interpolatedTitle = interpolate(legalData.page.metaTitle ?? legalData.page.title);
  interpolatedDescription = description ? interpolate(description) : undefined;
}
---

<BaseLayout
  title={isLegal ? interpolatedTitle : undefined}
  description={isLegal ? interpolatedDescription : undefined}
  alternateUrls={alternateUrls}
>
  {isLegal && legalData ? (
    <LegalPage data={legalData} locale={locale} />
  ) : Page && t ? (
    <Page t={t as never} />
  ) : null}
</BaseLayout>
