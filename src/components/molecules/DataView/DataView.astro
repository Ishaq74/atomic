---
/**
 * DataView — Responsive data display molecule.
 * Renders both table and card views, showing the appropriate one based on viewport or user selection.
 *
 * Slots:
 *   - `toolbar-start`: Extra controls before the mode selector (e.g., search input)
 *   - `toolbar-end`: Extra controls after the mode selector (e.g., filters)
 *   - `table`: The table view content
 *   - `cards`: The cards/list view content
 */
import { NativeSelect, NativeSelectOption } from '@atoms/native-select';

interface Props {
  /** Label for table mode */
  tableLabel?: string;
  /** Label for cards mode */
  cardsLabel?: string;
  class?: string;
}

const {
  tableLabel = 'Table',
  cardsLabel = 'Cards',
  class: className,
} = Astro.props;
---

<div class:list={['data-view', className]} data-mode="auto">
  <!-- Toolbar -->
  <div class="mb-4 flex flex-wrap items-center gap-3">
    <slot name="toolbar-start" />
    <div class="ml-auto flex items-center gap-3">
      <slot name="toolbar-end" />
      <NativeSelect class="data-view-mode w-auto text-sm">
        <NativeSelectOption value="table">{tableLabel}</NativeSelectOption>
        <NativeSelectOption value="cards">{cardsLabel}</NativeSelectOption>
      </NativeSelect>
    </div>
  </div>

  <!-- Table view -->
  <div class="data-view-table" data-view="table">
    <slot name="table" />
  </div>

  <!-- Cards view -->
  <div class="data-view-cards" data-view="cards">
    <slot name="cards" />
  </div>
</div>

<style>
  /* Auto mode (before JS): cards on mobile, table on desktop */
  .data-view[data-mode="auto"] [data-view="table"] {
    display: none;
  }
  .data-view[data-mode="auto"] [data-view="cards"] {
    display: block;
  }
  @media (min-width: 768px) {
    .data-view[data-mode="auto"] [data-view="table"] {
      display: block;
    }
    .data-view[data-mode="auto"] [data-view="cards"] {
      display: none;
    }
  }

  /* Explicit table mode — set via JS */
  :global(.data-view[data-mode="table"]) [data-view="table"] {
    display: block;
  }
  :global(.data-view[data-mode="table"]) [data-view="cards"] {
    display: none;
  }

  /* Explicit cards mode — set via JS */
  :global(.data-view[data-mode="cards"]) [data-view="table"] {
    display: none;
  }
  :global(.data-view[data-mode="cards"]) [data-view="cards"] {
    display: block;
  }
</style>

<script>
  function initDataViews() {
    document.querySelectorAll<HTMLElement>('.data-view').forEach((container) => {
      const select = container.querySelector('.data-view-mode');
      const nativeSelect = select?.closest('[data-slot="native-select-wrapper"]')?.querySelector('select') ?? select;
      if (!nativeSelect) return;

      // Set initial mode based on viewport
      const isDesktop = window.matchMedia('(min-width: 768px)').matches;
      const initialMode = isDesktop ? 'table' : 'cards';
      (nativeSelect as HTMLSelectElement).value = initialMode;
      container.dataset.mode = initialMode;

      nativeSelect.addEventListener('change', () => {
        container.dataset.mode = (nativeSelect as HTMLSelectElement).value;
      });
    });
  }
  initDataViews();
  document.addEventListener('astro:after-swap', initDataViews);
</script>
