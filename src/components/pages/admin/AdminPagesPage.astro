---
/**
 * AdminPagesPage — List, create, publish/unpublish, delete CMS pages.
 */
import type { AuthTranslations, Locale } from '@i18n/config';
import type { pages } from '@database/schemas';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@atoms/card';
import { Table, TableHeader, TableHead, TableBody, TableRow, TableCell } from '@atoms/table';
import Badge from '@atoms/badge/Badge.astro';
import Button from '@atoms/button/Button.astro';
import AdminPagination from '@molecules/AdminPagination/AdminPagination.astro';

type PageRow = typeof pages.$inferSelect;

interface Props {
  t: AuthTranslations;
  locale: Locale;
  pages: PageRow[];
  currentPage: number;
  totalPages: number;
  baseUrl: URL;
}

const { t, locale, pages: allPages, currentPage, totalPages, baseUrl } = Astro.props;
const cms = t.admin.cms.pages;
---

<pages-manager
  id="cms-pages-data"
  data-locale={locale}
  data-t-saved={cms.saved}
  data-t-deleted={cms.deleted}
  data-t-error={t.admin.cms.common.error}
  data-t-confirm={cms.confirmDelete}
>
  <Card>
    <CardHeader>
      <CardTitle>{cms.title}</CardTitle>
      <CardDescription>{cms.description}</CardDescription>
      <div class="flex justify-end">
        <Button id="create-page-btn" size="sm">{cms.createPage}</Button>
      </div>
    </CardHeader>
    <CardContent>
      {allPages.length === 0 ? (
        <p class="text-muted-foreground text-sm">{cms.noPages}</p>
      ) : (
        <div class="rounded-md border overflow-x-auto">
          <Table>
            <TableHeader>
              <TableRow>
                <TableHead>{cms.pageTitle}</TableHead>
                <TableHead>{cms.slug}</TableHead>
                <TableHead>{cms.template}</TableHead>
                <TableHead class="text-center">{cms.published}</TableHead>
                <TableHead>{t.admin.cms.common.actions}</TableHead>
              </TableRow>
            </TableHeader>
            <TableBody>
              {allPages.map((page) => (
                <TableRow class="cms-page-row" data-id={page.id}>
                  <TableCell class="font-medium">{page.title}</TableCell>
                  <TableCell class="text-muted-foreground text-sm">/{page.slug}</TableCell>
                  <TableCell class="text-sm">{page.template ?? 'default'}</TableCell>
                  <TableCell class="text-center">
                    <Badge variant={page.isPublished ? 'default' : 'secondary'}>
                      {page.isPublished ? cms.published : cms.draft}
                    </Badge>
                  </TableCell>
                  <TableCell>
                    <div class="flex gap-2">
                      <Button
                        size="sm"
                        variant="outline"
                        class="page-toggle-btn"
                        data-id={page.id}
                        data-published={String(page.isPublished)}
                      >
                        {page.isPublished ? cms.unpublish : cms.publish}
                      </Button>
                      <Button
                        size="sm"
                        variant="outline"
                        class="page-edit-btn"
                        data-id={page.id}
                      >
                        {cms.editPage}
                      </Button>
                      <Button
                        size="sm"
                        variant="error"
                        class="page-delete-btn"
                        data-id={page.id}
                      >
                        {t.admin.cms.common.delete}
                      </Button>
                    </div>
                  </TableCell>
                </TableRow>
              ))}
            </TableBody>
          </Table>
        </div>
      )}
    </CardContent>
  </Card>

  <AdminPagination currentPage={currentPage} totalPages={totalPages} baseUrl={baseUrl} />
</pages-manager>

<script>
  import { actions } from 'astro:actions';
  import { toast } from '@atoms/toast';

  class PagesManager extends HTMLElement {
    connectedCallback() {
      const locale = this.dataset.locale!;
      const tDeleted = this.dataset.tDeleted ?? 'Deleted.';
      const tError = this.dataset.tError ?? 'Error.';
      const tConfirm = this.dataset.tConfirm ?? 'Delete?';

      // ─── Create Page ───
      this.querySelector('#create-page-btn')?.addEventListener('click', async () => {
        const { error } = await actions.createPage({
          locale: locale as 'fr' | 'en' | 'es' | 'ar',
          slug: 'new-page-' + Date.now(),
          title: 'New Page',
        });
        if (!error) location.reload();
        else toast.error(error.message ?? tError);
      });

      // ─── Toggle Publish ───
      this.querySelectorAll<HTMLElement>('.page-toggle-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id!;
          const isPublished = btn.dataset.published === 'true';
          const { error } = await actions.publishPage({ id, isPublished: !isPublished });
          if (!error) location.reload();
          else toast.error(error.message ?? tError);
        });
      });

      // ─── Delete Page ───
      this.querySelectorAll<HTMLElement>('.page-delete-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          if (!confirm(tConfirm)) return;
          const id = btn.dataset.id!;
          const { error } = await actions.deletePage({ id });
          if (!error) { toast.success(tDeleted); btn.closest('.cms-page-row')?.remove(); }
          else toast.error(error.message ?? tError);
        });
      });

      // ─── Edit Page (redirect to edit page with sections) ───
      this.querySelectorAll<HTMLElement>('.page-edit-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.id!;
          const url = new URL(window.location.href);
          url.searchParams.set('edit', id);
          window.location.href = url.toString();
        });
      });
    }
  }

  customElements.define('pages-manager', PagesManager);
</script>
