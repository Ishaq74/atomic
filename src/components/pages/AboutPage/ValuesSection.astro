---
import type { HTMLAttributes } from "astro/types";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { tv } from "tailwind-variants";
import {
  Accordion,
  AccordionItem,
  AccordionTrigger,
  AccordionContent,
} from "@atoms/accordion";

interface ValueItem {
  title: string;
  description: string;
  image: ImageMetadata;
  value: string;
}

interface Props extends HTMLAttributes<"section"> {
  eyebrow?: string;
  title?: string;
  description?: string;
  items?: ValueItem[];
}

const featureSection = tv({
  base: "py-24 w-full mx-auto max-w-7xl px-4 @container",
});

const { eyebrow, title, description, items = [], class: className, ...rest } = Astro.props;
const defaultValue = items[0]?.value;
---

<section class={featureSection({ class: className })} {...rest}>
  <div class="mb-16 max-w-2xl">
    {eyebrow && (
      <span class="text-primary mb-4 block text-sm font-semibold tracking-wider uppercase">
        {eyebrow}
      </span>
    )}
    {title && (
      <h2 class="font-heading mb-4 text-3xl font-bold tracking-tight @xl:text-4xl @3xl:text-5xl">
        {title}
      </h2>
    )}
    {description && <p class="text-muted-foreground text-lg leading-relaxed">{description}</p>}
  </div>

  <div class="grid grid-cols-1 items-start gap-12 @2xl:grid-cols-2 @2xl:gap-24">
    <!-- Left: Accordion -->
    <div class="order-2 @2xl:order-1">
      <Accordion defaultValue={defaultValue} class="starwind-feature-accordion w-full space-y-3">
        {items.map((item, index) => (
          <AccordionItem value={item.value} class="border-b-0">
            <AccordionTrigger
              class="bg-muted/50 hover:text-foreground hover:bg-muted data-[state=open]:bg-muted group rounded-xl px-6 py-5 transition-all"
              data-index={index}
            >
              <span class="font-heading text-lg font-semibold">{item.title}</span>
            </AccordionTrigger>
            <AccordionContent class="mt-2 px-6">
              <p class="text-muted-foreground leading-relaxed">{item.description}</p>
            </AccordionContent>
          </AccordionItem>
        ))}
      </Accordion>
    </div>

    <!-- Right: Images -->
    <div class="order-1 @2xl:order-2">
      <div
        class="starwind-feature-image-wrapper bg-background relative aspect-4/3 overflow-hidden rounded-3xl border"
        data-active-index={items.findIndex((i) => i.value === defaultValue)}
      >
        {items.map((item, index) => (
          <div
            class="pointer-events-none absolute inset-0 h-full w-full opacity-0 transition-opacity duration-500 select-none data-[active=true]:pointer-events-auto data-[active=true]:opacity-100"
            data-index={index}
            data-active={item.value === defaultValue ? "true" : "false"}
          >
            <Image
              src={item.image}
              alt={item.title}
              class="h-full w-full object-cover transition-transform duration-700"
              width={800}
              height={600}
              loading="lazy"
              data-index={index}
              data-active={item.value === defaultValue ? "true" : "false"}
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function setupFeatureAccordion() {
    const accordions = document.querySelectorAll(".starwind-feature-accordion");

    accordions.forEach((accordion) => {
      const wrapper = accordion
        .closest("section")
        ?.querySelector(".starwind-feature-image-wrapper");
      if (!wrapper) return;

      const triggers = accordion.querySelectorAll(".starwind-accordion-trigger");
      const imageContainers = wrapper.querySelectorAll<HTMLElement>("[data-index]");

      triggers.forEach((trigger) => {
        trigger.addEventListener("click", () => {
          const index = trigger.getAttribute("data-index");
          if (index === null) return;

          wrapper.setAttribute("data-active-index", index);

          imageContainers.forEach((container) => {
            const isActive = container.getAttribute("data-index") === index;
            container.setAttribute("data-active", isActive ? "true" : "false");
          });
        });
      });
    });
  }

  setupFeatureAccordion();
  document.addEventListener("astro:after-swap", setupFeatureAccordion);
  document.addEventListener("starwind:init", setupFeatureAccordion);
</script>

<style>
  .starwind-feature-image-wrapper [data-active="true"] {
    z-index: 10;
  }
</style>
