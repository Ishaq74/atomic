---
import type { AuthTranslations, Locale } from '@i18n/config';
import { getAuthUrl } from '@i18n/utils';
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from '@atoms/card';
import Label from '@atoms/label/Label.astro';
import Input from '@atoms/input/Input.astro';
import Separator from '@atoms/separator/Separator.astro';
import AsyncButton from '@wow/AsyncButton.astro';

interface Props {
  t: AuthTranslations;
  locale: Locale;
  user: any;
}

const { t, locale } = Astro.props;
const signUpUrl = getAuthUrl(locale, 'sign-up', t);
const forgotPasswordUrl = getAuthUrl(locale, 'forgot-password', t);
---

<section class="flex min-h-[calc(100vh-8rem)] items-center justify-center px-4 py-12">
  <Card class="w-full max-w-md">
    <CardHeader class="text-center">
      <CardTitle class="text-2xl">{t.signIn.title}</CardTitle>
      <CardDescription>{t.signIn.description}</CardDescription>
    </CardHeader>
    <CardContent>
      <form id="sign-in-form" class="grid gap-4"
        data-success={t.signIn.success}
        data-errors={JSON.stringify(t.errors)}
        data-redirect={getAuthUrl(locale, 'dashboard', t)}
      >
        <div class="grid gap-2">
          <Label for="email">{t.signIn.email}</Label>
          <Input id="email" name="email" type="email" placeholder={t.signIn.emailPlaceholder} required />
        </div>

        <div class="grid gap-2">
          <Label for="password">{t.signIn.password}</Label>
          <Input id="password" name="password" type="password" placeholder={t.signIn.passwordPlaceholder} required />
        </div>

        <div class="flex justify-end">
          <a href={forgotPasswordUrl} class="text-primary hover:underline text-sm font-medium">{t.signIn.forgotPassword}</a>
        </div>

        <AsyncButton
          id="sign-in-btn"
          text={t.signIn.submit}
          variant="primary"
          size="md"
          class="w-full"
          type="button"
        />
      </form>
    </CardContent>
    <CardFooter class="flex-col gap-4">
      <Separator />
      <p class="text-muted-foreground text-sm">
        {t.signIn.noAccount}{' '}
        <a href={signUpUrl} class="text-primary hover:underline font-medium">{t.signIn.createAccount}</a>
      </p>
    </CardFooter>
  </Card>
</section>

<script>
  import { authClient } from '@lib/auth-client';
  import { toast } from '@atoms/toast';

  function init() {
    const form = document.getElementById('sign-in-form') as HTMLFormElement | null;
    const btn = document.getElementById('sign-in-btn');
    if (!form || !btn || btn.dataset.authInit === 'true') return;
    btn.dataset.authInit = 'true';

    const successMsg = form.dataset.success!;
    const errors: Record<string, string> = JSON.parse(form.dataset.errors!);
    const redirectUrl = form.dataset.redirect!;

    const inputs = {
      email: form.querySelector('#email') as HTMLInputElement,
      password: form.querySelector('#password') as HTMLInputElement,
    };

    const getErrorMsg = (code?: string) => (code && errors[code]) || errors.UNKNOWN || code || '';

    function clearErrors() {
      for (const input of Object.values(inputs)) {
        input.removeAttribute('aria-invalid');
      }
    }

    function markError(field: keyof typeof inputs) {
      inputs[field].setAttribute('aria-invalid', 'true');
      inputs[field].focus();
    }

    for (const input of Object.values(inputs)) {
      input.addEventListener('input', () => input.removeAttribute('aria-invalid'), { once: false });
    }

    function validate(): string | null {
      clearErrors();
      if (!inputs.email.value.trim()) { markError('email'); return 'INVALID_EMAIL'; }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(inputs.email.value.trim())) { markError('email'); return 'INVALID_EMAIL'; }
      if (!inputs.password.value) { markError('password'); return 'INVALID_PASSWORD'; }
      return null;
    }

    btn.addEventListener('async-button:execute', async (e) => {
      const { resolve, reject } = (e as CustomEvent).detail;

      const validationError = validate();
      if (validationError) {
        toast.error(getErrorMsg(validationError));
        return reject();
      }

      let settled = false;
      const timeout = setTimeout(() => {
        if (!settled) { settled = true; toast.error(errors.UNKNOWN || ''); reject(); }
      }, 15000);

      try {
        const { error } = await authClient.signIn.email({
          email: inputs.email.value.trim(),
          password: inputs.password.value,
        });
        if (settled) return;
        settled = true;
        clearTimeout(timeout);
        if (error) {
          clearErrors();
          // Keep sign-in errors vague — highlight both fields
          markError('password');
          inputs.email.setAttribute('aria-invalid', 'true');
          toast.error(getErrorMsg(error.code));
          return reject();
        }
        toast.success(successMsg);
        resolve();
        setTimeout(() => window.location.href = redirectUrl, 600);
      } catch {
        if (settled) return;
        settled = true;
        clearTimeout(timeout);
        toast.error(errors.UNKNOWN || '');
        reject();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:after-swap', init);
</script>
