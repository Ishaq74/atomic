---
import type { AuthTranslations, Locale } from '@i18n/config';
import type { AppUser } from '@/lib/types';
import { getAuthUrl } from '@i18n/utils';
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from '@atoms/card';
import Label from '@atoms/label/Label.astro';
import Input from '@atoms/input/Input.astro';
import Separator from '@atoms/separator/Separator.astro';
import AsyncButton from '@wow/AsyncButton.astro';

interface Props {
  t: AuthTranslations;
  locale: Locale;
  user: AppUser | null;
}

const { t, locale } = Astro.props;
const signInUrl = getAuthUrl(locale, 'sign-in', t);
---

<section class="flex min-h-[calc(100vh-8rem)] items-center justify-center px-4 py-12">
  <Card class="w-full max-w-md">
    <CardHeader class="text-center">
      <CardTitle class="text-2xl">{t.resetPassword.title}</CardTitle>
      <CardDescription>{t.resetPassword.description}</CardDescription>
    </CardHeader>
    <CardContent>
      <form id="reset-password-form" class="grid gap-4"
        data-errors={JSON.stringify(t.errors)}
        data-success-title={t.resetPassword.successTitle}
        data-success-description={t.resetPassword.successDescription}
        data-sign-in-url={signInUrl}
        data-sign-in-label={t.resetPassword.goToSignIn}
        data-invalid-token={t.resetPassword.invalidToken}
        data-expired-token={t.resetPassword.expiredToken}
      >
        <div class="grid gap-2">
          <Label for="new-password">{t.resetPassword.newPassword}</Label>
          <Input id="new-password" name="new-password" type="password" placeholder={t.resetPassword.newPasswordPlaceholder} required autocomplete="new-password" />
        </div>

        <div class="grid gap-2">
          <Label for="confirm-password">{t.resetPassword.confirmPassword}</Label>
          <Input id="confirm-password" name="confirm-password" type="password" placeholder={t.resetPassword.confirmPasswordPlaceholder} required autocomplete="new-password" />
        </div>

        <AsyncButton
          id="reset-password-btn"
          text={t.resetPassword.submit}
          variant="primary"
          size="md"
          class="w-full"
          type="submit"
        />
      </form>

      <div id="reset-password-success" class="hidden text-center py-4">
        <div class="text-success mb-2 text-lg font-semibold" id="success-title"></div>
        <p class="text-muted-foreground text-sm mb-4" id="success-description"></p>
        <a id="success-sign-in-link" href={signInUrl} class="text-primary-deep hover:underline font-medium">{t.resetPassword.goToSignIn}</a>
      </div>

      <div id="reset-password-error" class="hidden text-center py-4">
        <div class="text-destructive mb-2 text-lg font-semibold" id="error-title"></div>
        <p class="text-muted-foreground text-sm mb-4" id="error-description"></p>
        <a href={signInUrl} class="text-primary-deep hover:underline font-medium">{t.resetPassword.goToSignIn}</a>
      </div>
    </CardContent>
    <CardFooter class="flex-col gap-4">
      <Separator />
      <p class="text-muted-foreground text-sm">
        <a href={signInUrl} class="text-primary-deep hover:underline font-medium">{t.resetPassword.goToSignIn}</a>
      </p>
    </CardFooter>
  </Card>
</section>

<script>
  import { authClient } from '@lib/auth-client';
  import { toast } from '@atoms/toast';

  function init() {
    const form = document.getElementById('reset-password-form') as HTMLFormElement | null;
    const btn = document.getElementById('reset-password-btn');
    if (!form || !btn || btn.dataset.authInit === 'true') return;
    btn.dataset.authInit = 'true';

    const errors: Record<string, string> = JSON.parse(form.dataset.errors!);
    const successTitle = form.dataset.successTitle!;
    const successDescription = form.dataset.successDescription!;
    const signInUrl = form.dataset.signInUrl!;
    const signInLabel = form.dataset.signInLabel!;
    const invalidTokenMsg = form.dataset.invalidToken!;
    const expiredTokenMsg = form.dataset.expiredToken!;

    // Extract token from URL query params
    const params = new URLSearchParams(window.location.search);
    const token = params.get('token');
    const urlError = params.get('error');

    // If URL has error param, show error immediately
    if (urlError || !token) {
      form.classList.add('hidden');
      const errorEl = document.getElementById('reset-password-error')!;
      document.getElementById('error-title')!.textContent =
        urlError === 'EXPIRED_TOKEN' ? expiredTokenMsg : invalidTokenMsg;
      document.getElementById('error-description')!.textContent = '';
      errorEl.classList.remove('hidden');
      return;
    }

    const inputs = {
      newPassword: form.querySelector('#new-password') as HTMLInputElement,
      confirmPassword: form.querySelector('#confirm-password') as HTMLInputElement,
    };

    for (const input of Object.values(inputs)) {
      input.addEventListener('input', () => input.removeAttribute('aria-invalid'));
    }

    function clearErrors() {
      for (const input of Object.values(inputs)) {
        input.removeAttribute('aria-invalid');
      }
    }

    form.addEventListener('submit', (e) => e.preventDefault());

    btn.addEventListener('async-button:execute', async (e) => {
      const { resolve, reject } = (e as CustomEvent).detail;
      clearErrors();

      const newPassword = inputs.newPassword.value;
      const confirmPassword = inputs.confirmPassword.value;

      if (!newPassword || newPassword.length < 8) {
        inputs.newPassword.setAttribute('aria-invalid', 'true');
        inputs.newPassword.focus();
        toast.error(errors.PASSWORD_TOO_SHORT || errors.UNKNOWN || '');
        return reject();
      }

      if (newPassword !== confirmPassword) {
        inputs.confirmPassword.setAttribute('aria-invalid', 'true');
        inputs.confirmPassword.focus();
        toast.error(errors.PASSWORDS_DO_NOT_MATCH || errors.UNKNOWN || '');
        return reject();
      }

      let settled = false;
      const timeout = setTimeout(() => {
        if (!settled) { settled = true; toast.error(errors.UNKNOWN || ''); reject(); }
      }, 15000);

      try {
        const { error } = await authClient.resetPassword({
          newPassword,
          token: token!,
        });
        if (settled) return;
        settled = true;
        clearTimeout(timeout);

        if (error) {
          const code = error.code;
          if (code === 'INVALID_TOKEN') {
            toast.error(invalidTokenMsg);
          } else if (code === 'EXPIRED_TOKEN') {
            toast.error(expiredTokenMsg);
          } else {
            toast.error(errors[code ?? ''] || errors.UNKNOWN || '');
          }
          return reject();
        }

        form.classList.add('hidden');
        const successEl = document.getElementById('reset-password-success')!;
        document.getElementById('success-title')!.textContent = successTitle;
        document.getElementById('success-description')!.textContent = successDescription;
        const link = document.getElementById('success-sign-in-link') as HTMLAnchorElement;
        link.href = signInUrl;
        link.textContent = signInLabel;
        successEl.classList.remove('hidden');
        resolve();
      } catch {
        if (settled) return;
        settled = true;
        clearTimeout(timeout);
        toast.error(errors.UNKNOWN || '');
        reject();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:after-swap', init);
</script>
