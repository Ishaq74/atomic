---
import type { AuthTranslations, Locale } from '@i18n/config';
import { getAuthUrl } from '@i18n/utils';
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from '@atoms/card';
import Label from '@atoms/label/Label.astro';
import Input from '@atoms/input/Input.astro';
import Separator from '@atoms/separator/Separator.astro';
import AsyncButton from '@wow/AsyncButton.astro';

interface Props {
  t: AuthTranslations;
  locale: Locale;
  user: any;
}

const { t, locale } = Astro.props;
const signInUrl = getAuthUrl(locale, 'sign-in', t);
---

<section class="flex min-h-[calc(100vh-8rem)] items-center justify-center px-4 py-12">
  <Card class="w-full max-w-md">
    <CardHeader class="text-center">
      <CardTitle class="text-2xl">{t.forgotPassword.title}</CardTitle>
      <CardDescription>{t.forgotPassword.description}</CardDescription>
    </CardHeader>
    <CardContent>
      <form id="forgot-password-form" class="grid gap-4"
        data-errors={JSON.stringify(t.errors)}
        data-success-title={t.forgotPassword.successTitle}
        data-success-description={t.forgotPassword.successDescription}
        data-reset-url={getAuthUrl(locale, 'reset-password', t)}
      >
        <div class="grid gap-2">
          <Label for="email">{t.forgotPassword.email}</Label>
          <Input id="email" name="email" type="email" placeholder={t.forgotPassword.emailPlaceholder} required />
        </div>

        <AsyncButton
          id="forgot-password-btn"
          text={t.forgotPassword.submit}
          variant="primary"
          size="md"
          class="w-full"
          type="button"
        />
      </form>

      <div id="forgot-password-success" class="hidden text-center py-4">
        <div class="text-success mb-2 text-lg font-semibold" id="success-title"></div>
        <p class="text-muted-foreground text-sm" id="success-description"></p>
      </div>
    </CardContent>
    <CardFooter class="flex-col gap-4">
      <Separator />
      <p class="text-muted-foreground text-sm">
        <a href={signInUrl} class="text-primary hover:underline font-medium">{t.forgotPassword.backToSignIn}</a>
      </p>
    </CardFooter>
  </Card>
</section>

<script>
  import { authClient } from '@lib/auth-client';
  import { toast } from '@atoms/toast';

  function init() {
    const form = document.getElementById('forgot-password-form') as HTMLFormElement | null;
    const btn = document.getElementById('forgot-password-btn');
    if (!form || !btn || btn.dataset.authInit === 'true') return;
    btn.dataset.authInit = 'true';

    const errors: Record<string, string> = JSON.parse(form.dataset.errors!);
    const successTitle = form.dataset.successTitle!;
    const successDescription = form.dataset.successDescription!;
    const resetPageUrl = form.dataset.resetUrl!;

    const emailInput = form.querySelector('#email') as HTMLInputElement;

    emailInput.addEventListener('input', () => emailInput.removeAttribute('aria-invalid'));

    btn.addEventListener('async-button:execute', async (e) => {
      const { resolve, reject } = (e as CustomEvent).detail;

      const email = emailInput.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        emailInput.setAttribute('aria-invalid', 'true');
        emailInput.focus();
        toast.error(errors.INVALID_EMAIL || errors.UNKNOWN || '');
        return reject();
      }

      let settled = false;
      const timeout = setTimeout(() => {
        if (!settled) { settled = true; toast.error(errors.UNKNOWN || ''); reject(); }
      }, 15000);

      try {
        // redirectTo points to our reset-password page; better-auth appends ?token=...
        await authClient.requestPasswordReset({
          email,
          redirectTo: resetPageUrl,
        });
        if (settled) return;
        settled = true;
        clearTimeout(timeout);

        // Always show success (even if user doesn't exist) to prevent enumeration
        form.classList.add('hidden');
        const successEl = document.getElementById('forgot-password-success')!;
        document.getElementById('success-title')!.textContent = successTitle;
        document.getElementById('success-description')!.textContent = successDescription;
        successEl.classList.remove('hidden');
        resolve();
      } catch {
        if (settled) return;
        settled = true;
        clearTimeout(timeout);
        toast.error(errors.UNKNOWN || '');
        reject();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:after-swap', init);
</script>
