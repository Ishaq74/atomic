---
/**
 * MediaPicker — Reusable media browser dialog.
 * Opens a modal with the media library, allows selecting a file, and fires a
 * custom event with the selected file's URL and alt text.
 *
 * Usage:
 *   <MediaPicker id="my-picker" locale={locale} />
 *   <button data-media-picker="my-picker">Choose image</button>
 *
 * Listening for selection (in your custom element):
 *   document.querySelector('#my-picker').addEventListener('media-select', (e) => {
 *     const { url, alt, fileId } = e.detail;
 *   });
 */
import type { Locale } from '@i18n/config';
import { getAllMediaFiles, getMediaFolders } from '@database/loaders/media.loader';
import type { MediaFolderNode, MediaFileWithAlts } from '@database/loaders/media.loader';
import { Input } from '@atoms/input';
import Button from '@atoms/button/Button.astro';
import { Badge } from '@atoms/badge';

interface Props {
  id: string;
  locale: Locale;
}

const { id, locale } = Astro.props;
const [allFiles, folderTree] = await Promise.all([getAllMediaFiles(), getMediaFolders()]);

function formatSize(bytes: number): string {
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
}

function flattenFolderIds(nodes: MediaFolderNode[]): { id: string; name: string }[] {
  const result: { id: string; name: string }[] = [];
  for (const n of nodes) {
    result.push({ id: n.id, name: n.name });
    result.push(...flattenFolderIds(n.children));
  }
  return result;
}
const folders = flattenFolderIds(folderTree);
---

<media-picker
  id={id}
  data-locale={locale}
  data-files={JSON.stringify(allFiles.map(f => ({
    id: f.id,
    folderId: f.folderId,
    filename: f.filename,
    url: f.url,
    mimeType: f.mimeType,
    size: f.size,
    width: f.width,
    height: f.height,
    alts: f.alts,
  })))}
  data-folders={JSON.stringify(folders)}
  class="hidden"
>
  {/* Backdrop */}
  <div class="media-picker-backdrop fixed inset-0 z-50 bg-black/50 backdrop-blur-sm" data-action="close"></div>

  {/* Dialog */}
  <div class="media-picker-dialog fixed inset-4 z-50 mx-auto my-auto flex max-h-[90vh] max-w-4xl flex-col overflow-hidden rounded-xl border bg-background shadow-xl">
    {/* Header */}
    <div class="flex items-center justify-between border-b px-4 py-3">
      <h3 class="text-lg font-semibold">Sélectionner un média</h3>
      <div class="flex items-center gap-3">
        <Input type="search" placeholder="Rechercher…" class="h-8 w-48 text-sm media-picker-search" />
        <select class="media-picker-folder-filter h-8 rounded-md border bg-background px-2 text-sm">
          <option value="">Tous les dossiers</option>
          {folders.map(f => <option value={f.id}>{f.name}</option>)}
        </select>
        <button class="media-picker-close rounded-md p-1 hover:bg-muted" data-action="close">
          <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
        </button>
      </div>
    </div>

    {/* Grid */}
    <div class="flex-1 overflow-y-auto p-4">
      <div class="media-picker-grid grid gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
        {allFiles.map((file) => {
          const alt = file.alts.find(a => a.locale === locale)?.alt ?? '';
          return (
            <button
              type="button"
              class="media-picker-item group relative flex flex-col overflow-hidden rounded-lg border transition-all hover:border-primary/50 focus:ring-2 focus:ring-primary"
              data-file-id={file.id}
              data-url={file.url}
              data-alt={alt}
              data-folder-id={file.folderId ?? ''}
              data-filename={file.filename}
            >
              <div class="relative aspect-square bg-muted">
                {file.mimeType.startsWith('image/') ? (
                  <img src={file.url} alt={alt || file.filename} class="h-full w-full object-cover" loading="lazy" />
                ) : (
                  <div class="flex h-full items-center justify-center">
                    <svg class="size-8 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
                  </div>
                )}
              </div>
              <div class="p-1.5">
                <p class="truncate text-[11px] font-medium">{file.filename}</p>
                <p class="text-[10px] text-muted-foreground">{formatSize(file.size)}</p>
              </div>
            </button>
          );
        })}
      </div>
      {allFiles.length === 0 && (
        <p class="py-12 text-center text-sm text-muted-foreground">Aucun média. Uploadez des fichiers dans la bibliothèque de médias.</p>
      )}
    </div>

    {/* Footer */}
    <div class="flex items-center justify-between border-t px-4 py-3">
      <span class="media-picker-count text-sm text-muted-foreground">{allFiles.length} fichiers</span>
      <div class="flex gap-2">
        <Button size="sm" variant="outline" class="media-picker-cancel-btn" data-action="close">Annuler</Button>
        <Button size="sm" class="media-picker-select-btn" disabled>Sélectionner</Button>
      </div>
    </div>
  </div>
</media-picker>

<script>
  class MediaPickerElement extends HTMLElement {
    private selectedFileId: string | null = null;
    private files: Array<{
      id: string;
      folderId: string | null;
      filename: string;
      url: string;
      mimeType: string;
      size: number;
      width: number | null;
      height: number | null;
      alts: { locale: string; alt: string; title: string | null }[];
    }> = [];

    connectedCallback() {
      try {
        this.files = JSON.parse(this.dataset.files ?? '[]');
      } catch { this.files = []; }

      // Close handlers
      this.querySelectorAll('[data-action="close"]').forEach(el =>
        el.addEventListener('click', () => this.close())
      );

      // Item click
      this.querySelectorAll<HTMLElement>('.media-picker-item').forEach(item => {
        item.addEventListener('click', () => this.selectItem(item));
        item.addEventListener('dblclick', () => {
          this.selectItem(item);
          this.confirmSelection();
        });
      });

      // Select button
      this.querySelector('.media-picker-select-btn')?.addEventListener('click', () => this.confirmSelection());

      // Search
      const searchInput = this.querySelector<HTMLInputElement>('.media-picker-search');
      searchInput?.addEventListener('input', () => this.filterItems());

      // Folder filter
      const folderFilter = this.querySelector<HTMLSelectElement>('.media-picker-folder-filter');
      folderFilter?.addEventListener('change', () => this.filterItems());

      // Global trigger buttons
      document.querySelectorAll<HTMLElement>(`[data-media-picker="${this.id}"]`).forEach(btn => {
        btn.addEventListener('click', () => this.open());
      });
    }

    open() {
      this.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    close() {
      this.classList.add('hidden');
      document.body.style.overflow = '';
      this.selectedFileId = null;
      this.querySelectorAll('.media-picker-item').forEach(el => el.classList.remove('ring-2', 'ring-primary'));
      const btn = this.querySelector<HTMLButtonElement>('.media-picker-select-btn');
      if (btn) btn.disabled = true;
    }

    private selectItem(item: HTMLElement) {
      this.querySelectorAll('.media-picker-item').forEach(el => el.classList.remove('ring-2', 'ring-primary'));
      item.classList.add('ring-2', 'ring-primary');
      this.selectedFileId = item.dataset.fileId ?? null;
      const btn = this.querySelector<HTMLButtonElement>('.media-picker-select-btn');
      if (btn) btn.disabled = false;
    }

    private confirmSelection() {
      if (!this.selectedFileId) return;
      const item = this.querySelector<HTMLElement>(`[data-file-id="${CSS.escape(this.selectedFileId)}"]`);
      if (!item) return;

      this.dispatchEvent(new CustomEvent('media-select', {
        detail: {
          fileId: this.selectedFileId,
          url: item.dataset.url,
          alt: item.dataset.alt,
          filename: item.dataset.filename,
        },
        bubbles: true,
      }));
      this.close();
    }

    private filterItems() {
      const search = this.querySelector<HTMLInputElement>('.media-picker-search')?.value.toLowerCase() ?? '';
      const folderId = this.querySelector<HTMLSelectElement>('.media-picker-folder-filter')?.value ?? '';

      let visibleCount = 0;
      this.querySelectorAll<HTMLElement>('.media-picker-item').forEach(item => {
        const filename = (item.dataset.filename ?? '').toLowerCase();
        const itemFolder = item.dataset.folderId ?? '';

        const matchSearch = !search || filename.includes(search);
        const matchFolder = !folderId || itemFolder === folderId;

        const show = matchSearch && matchFolder;
        item.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });

      const countEl = this.querySelector('.media-picker-count');
      if (countEl) countEl.textContent = `${visibleCount} fichiers`;
    }
  }

  customElements.define('media-picker', MediaPickerElement);
</script>
