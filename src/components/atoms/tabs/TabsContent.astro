---
import type { HTMLAttributes } from "astro/types";
import { tv } from "tailwind-variants";

interface Props extends Omit<HTMLAttributes<"div">, "id" | "role" | "tabindex" | "hidden"> {
  value: string;
  /** Render this tab visible on the server to avoid CLS */
  defaultActive?: boolean;
}

export const tabsContent = tv({
  base: "mt-2 focus-visible:outline-2 focus-visible:outline-offset-2",
});

const { value, defaultActive = false, class: className, ...rest } = Astro.props;
---

<div
  class={tabsContent({ class: className })}
  data-tabs-content
  data-value={value}
  data-state={defaultActive ? "active" : "inactive"}
  role="tabpanel"
  tabindex="0"
  hidden={!defaultActive}
  {...rest}
  data-slot="tabs-content"
>
  <slot />
</div>
