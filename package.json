{
  "name": "atomic",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "postinstall": "node scripts/patch-chrome-launcher.cjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint \"src/**/*.{js,ts,astro}\"",
    "lint:fix": "eslint \"src/**/*.{js,ts,astro}\" --fix",
    "check": "astro check",
    "db:check": "npx tsx src/database/commands/db.check.ts",
    "db:compare": "npx tsx src/database/commands/db.compare.ts",
    "db:generate": "npx tsx src/database/commands/db.generate.ts",
    "db:infra": "npx tsx src/database/commands/db.infra.ts",
    "db:migrate": "npx tsx src/database/commands/db.migrate.ts",
    "db:reset": "npx tsx src/database/commands/db.reset.ts",
    "db:seed": "npx tsx src/database/commands/db.seed.ts",
    "db:seed-media": "npx tsx src/database/commands/db.seed-media.ts",
    "db:sync": "npx tsx src/database/commands/db.sync.ts",
    "db:cleanup-audit": "npx tsx src/database/commands/db.cleanup-audit.ts",
    "smtp:check": "npx tsx src/smtp/commands/smtp.check.ts",
    "logs:rotate": "npx tsx src/smtp/commands/logs.rotate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:report": "node tests/helpers/vitest-report.cjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "node tests/helpers/playwright-report.cjs",
    "a11y:setup": "tsx tests/a11y/setup.ts",
    "a11y:teardown": "tsx tests/a11y/setup.ts --teardown",
    "a11y:pa11y": "pa11y-ci --config .pa11yci.cjs",
    "a11y:lighthouse": "lhci autorun --config lighthouserc.cjs",
    "a11y:lighthouse:authed": "node tests/a11y/lhci-authed.cjs",
    "a11y:lighthouse:rename": "node tests/a11y/lhci-rename.cjs",
    "a11y:lighthouse:report": "node tests/a11y/lhci-report.cjs",
    "a11y:lighthouse:report:contrast": "node tests/a11y/lhci-report.cjs --contrast",
    "a11y:report": "node tests/helpers/lighthouse-report.cjs",
    "a11y": "node tests/a11y/run.cjs",
    "a11y:pa11y-only": "node tests/a11y/run.cjs --pa11y",
    "a11y:lighthouse-only": "node tests/a11y/run.cjs --lighthouse",
    "qa": "pnpm check && pnpm build && pnpm lint && pnpm test -- --coverage && pnpm test:report && pnpm test:e2e && pnpm test:e2e:report && pnpm a11y",
    "qa:offline": "pnpm check && pnpm build && pnpm lint && pnpm test -- --coverage && pnpm test:report"
  },
  "dependencies": {
    "@astrojs/node": "10.0.5",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@iconify-json/circle-flags": "^1.2.10",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/openmoji": "^1.2.23",
    "@tabler/icons": "^3",
    "@tailwindcss/forms": "^0.5",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "6.1.8",
    "astro-icon": "^1.1.5",
    "better-auth": "^1.5.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "isomorphic-dompurify": "^3.3.0",
    "motion": "^12.36.0",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3",
    "tailwind-variants": "^3",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "pa11y-ci": "^4.1.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}